{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TRADING HELP",
  "version": "0.1.5",
  "identifier": "com.trading.help",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TRADING HELP",
        "width": 1100,
        "height": 850,
        "resizable": true
      }
    ],
   "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxQUY5OTVEQjg5M0M4OTQKUldTVXlKTzRYWm12Y2Ivd3BiRWJneVEwYVVFNEJYV0kzY0tPeXBrb3luZ0pDMnlyU09mSmRKVmwK",
      "endpoints": [
        "https://github.com/damiankas1122-crypto/trading-help/releases/latest/download/latest.json"
      ]
    }
  }
}
